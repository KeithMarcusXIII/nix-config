# Phase 1: Inject secrets from Bitwarden Secrets Manager BEFORE devenv evaluation.
# This ensures builtins.getEnv in devenv.nix can read them during Nix evaluation.
# Uses nix run because bws (unfree) is a devenv package not yet on PATH.
eval "$(NIXPKGS_ALLOW_UNFREE=1 nix run --impure nixpkgs#bws -- secret list 885d83f3-063b-4ba7-bddc-b45a00fd59b9 --output env | sed 's/^/export /')"

# Phase 2: Activate devenv with --impure so builtins.getEnv can read the environment.
eval "$(devenv direnvrc)"
use devenv --impure